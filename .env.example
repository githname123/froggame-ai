# Server
PORT=3001
HOST=0.0.0.0

# Blockchain - X Layer
RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196
GAME_CONTRACT_ADDRESS=0x_YOUR_CONTRACT_ADDRESS
OEOE_TOKEN=0x_YOUR_TOKEN_ADDRESS
SERVER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# OnchainOS API
ONCHAINOS_API_KEY=your_onchainos_api_key_here
ONCHAINOS_WALLET=0x_your_agentic_wallet_address

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/froggame

# Admin
ADMIN_SECRET=your_admin_secret

# CORS (comma-separated origins, leave empty for open)
CORS_ORIGINS=
